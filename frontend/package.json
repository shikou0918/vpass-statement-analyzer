{
  "name": "vpass-statement-analyzer-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --configLoader native",
    "dev:docker": "vite --host 0.0.0.0 --configLoader native",
    "build": "vue-tsc --noEmit && vite build --configLoader native",
